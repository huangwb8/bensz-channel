APP_NAME="Bensz Channel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:6542
APP_TIMEZONE=Asia/Shanghai

SITE_NAME="Bensz Channel"
SITE_TAGLINE="类 QQ 频道的 Web 社区原型，支持静态游客访问与成员互动"

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bensz_channel
DB_USERNAME=bensz
DB_PASSWORD=bensz_secret

SESSION_DRIVER=database
SESSION_COOKIE=bensz_channel_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_TIMEOUT=10
MAIL_FROM_ADDRESS="noreply@bensz-channel.local"
MAIL_FROM_NAME="${APP_NAME}"

AUTH_OTP_TTL=10
AUTH_OTP_LENGTH=6
AUTH_QR_TTL=10
AUTH_DRIVER=better_auth
AUTH_PREVIEW_CODES=true
ARTICLE_IMAGE_MAX_MB=50
VIDEO_UPLOAD_MAX_MB=500
BETTER_AUTH_URL=http://auth:3001
BETTER_AUTH_INTERNAL_SECRET=change-me-in-production
BETTER_AUTH_TIMEOUT=5
STATIC_SITE_ENABLED=true

ADMIN_NAME="频道管理员"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ASSET_URL=
CDN_MODE=origin
CDN_ASSET_URL=
CDN_STORAGE_PROVIDER=dogecloud
CDN_STORAGE_ACCESS_KEY=
CDN_STORAGE_SECRET_KEY=
CDN_STORAGE_BUCKET=
CDN_STORAGE_REGION=auto
CDN_STORAGE_ENDPOINT=
CDN_STORAGE_PUBLIC_URL=
CDN_SYNC_ENABLED=false
CDN_SYNC_ON_BUILD=true
VITE_APP_NAME="${APP_NAME}"
