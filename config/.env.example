# ============================================
# Docker Compose 直接引用的公开配置
# ============================================
# 这些变量被 docker-compose.yml 直接引用，必须保留在 .env 中
# 其它公开配置请查看 config/config.toml

# 端口映射（docker-compose ports 配置需要）
WEB_PORT=6542
MAILPIT_PORT=8025

# 静态站点配置（docker-compose volumes 配置需要）
STATIC_SITE_OUTPUT_DIR=static

# PostgreSQL 配置（docker-compose healthcheck 和镜像初始化需要）
POSTGRES_DB=bensz_channel
POSTGRES_USER=bensz

# ============================================
# 密钥类配置（敏感信息）
# ============================================

# Laravel 应用密钥（运行 `php artisan key:generate` 生成）
APP_KEY=

# 数据库密码
DB_PASSWORD=bensz_secret
POSTGRES_PASSWORD=bensz_secret

# Better Auth 密钥（生产环境请使用强随机字符串）
BETTER_AUTH_SECRET=change-me-before-production
BETTER_AUTH_INTERNAL_SECRET=change-me-before-production

# 邮件服务凭证
MAIL_USERNAME=
MAIL_PASSWORD=

# 管理员密码（首次启动时创建管理员账号）
ADMIN_PASSWORD=admin123456

# AWS 凭证（可选）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Slack 集成凭证（可选）
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# 第三方登录凭证（可选）
WECHAT_CLIENT_ID=
QQ_CLIENT_ID=
