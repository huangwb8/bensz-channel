# ============================================
# Docker Compose 直接引用的公开配置
# ============================================
# 这些变量被 docker-compose.yml 直接引用，必须保留在 .env 中
# 其它公开配置请查看 config/config.toml

# 端口映射（docker-compose ports 配置需要）
WEB_PORT=6542
MAILPIT_PORT=8025

# 静态站点配置（docker-compose volumes 配置需要）
STATIC_SITE_OUTPUT_DIR=static

# 媒体上传限制（MB）
ARTICLE_IMAGE_MAX_MB=50
VIDEO_UPLOAD_MAX_MB=500

# PostgreSQL 配置（docker-compose healthcheck 和镜像初始化需要）
DB_HOST=postgres
POSTGRES_DB=bensz_channel
POSTGRES_USER=bensz

# Laravel 数据库连接配置（web 服务需要）
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bensz_channel
DB_USERNAME=bensz

# ============================================
# 密钥类配置（敏感信息）
# ============================================

# Laravel 应用密钥（运行 `php artisan key:generate` 生成）
APP_KEY=

# 数据库密码
DB_PASSWORD=bensz_secret
POSTGRES_PASSWORD=bensz_secret

# 项目时区（默认北京时间）
APP_TIMEZONE=Asia/Shanghai

# Better Auth 密钥（生产环境请使用强随机字符串）
BETTER_AUTH_SECRET=change-me-before-production
BETTER_AUTH_INTERNAL_SECRET=change-me-before-production

# 邮件服务凭证
MAIL_USERNAME=
MAIL_PASSWORD=

# 管理员密码（首次启动时创建管理员账号）
ADMIN_PASSWORD=admin123456

# AWS 凭证（可选）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CDN 对象存储配置（可选）
CDN_MODE=origin
CDN_ASSET_URL=
CDN_STORAGE_PROVIDER=dogecloud
CDN_STORAGE_ACCESS_KEY=
CDN_STORAGE_SECRET_KEY=
CDN_STORAGE_BUCKET=
CDN_STORAGE_REGION=auto
CDN_STORAGE_ENDPOINT=
CDN_STORAGE_PUBLIC_URL=
CDN_SYNC_ENABLED=false
CDN_SYNC_ON_BUILD=true

# Slack 集成凭证（可选）
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# 第三方登录凭证（可选）
WECHAT_CLIENT_ID=
QQ_CLIENT_ID=
