NODE_ENV=development
PORT=3001
LOG_LEVEL=info

BETTER_AUTH_BASE_URL=http://localhost:3001
BETTER_AUTH_DATABASE_URL=postgres://bensz:bensz_secret@127.0.0.1:5432/bensz_channel?options=-c%20search_path%3Dauth,public
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_INTERNAL_SECRET=change-me-too
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:6542

AUTH_OTP_LENGTH=6
AUTH_OTP_TTL=10
AUTH_PREVIEW_CODES=true

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_ADDRESS=noreply@bensz-channel.local
MAIL_FROM_NAME=Bensz Channel
